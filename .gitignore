# --- ClojureScript / shadow-cljs / Electron app (0.2.0 / 0.3.0) ---
# (note: a trailing "# comment" on a pattern line is NOT a gitignore comment — keep comments on own lines)
node_modules/
.shadow-cljs/
.cpcache/
.cache/
target/
*.log

# Generated/vendored WebAssembly artifacts, copied into resources/public/js/ at build time so the
# compiled app and the bundled CLI/TUI load them from disk (found relative to the script's __dirname):
#   tree-sitter grammars                                    -> `npm run grammars:sync`
#   @resvg/resvg-wasm (terminal graphics, vinary.terminal.*) -> `npm run graphics:sync` (run by compile:cli/tui)
*.wasm
*.wasm.map

# compiled output, regenerated by shadow-cljs release
# (all five builds: main, renderer, test, and the cli/tui terminal previewers under dist/cli, dist/tui)
dist/
resources/public/js/cljs-runtime/
resources/public/js/main.js
resources/public/js/manifest.edn
# the lazily-loaded @codemirror source-view chunk + the @mathjax math-engine chunk + their module-loader
# manifest (renderer code-splits)
resources/public/js/source-view.js
resources/public/js/math-engine.js
resources/public/js/module-loader.edn
resources/public/js/module-loader.json

# Vendored static assets (Font Awesome + synced self-hosted fonts), copied from node_modules.
# Regenerate with `npm run assets:sync`.
# Hand-vendored and TRACKED (do NOT ignore): assets/fonts/fonts.css, and assets/fonts/lm-roman/
# (Latin Modern Roman — the prose/math body font, GUST Font License).
resources/public/assets/fa/
resources/public/assets/fonts/noto-sans/
resources/public/assets/fonts/fira-code/

# Vendored PDF.js worker + data assets (cmaps/standard_fonts/wasm/iccs), copied from node_modules.
# Regenerate with `npm run pdfjs:sync`.
resources/public/pdf/

# --- legacy v0.1.0 (patch-overlay tool) native addon artifacts ---
src/mouse-forward-back/build/
src/mouse-forward-back/node_modules/
*.vv.bak

# OS / editor cruft
.DS_Store
*.swp
*~
