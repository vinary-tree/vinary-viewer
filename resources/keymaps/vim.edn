;; vinary-viewer vim keymap (modal: normal/insert/visual; leader = SPC; ":" ex; "/" search).
;; Nested map = key sequence; "SPC" normalizes to the space token at load.
{:name :vim
 :initial-mode :normal
 :timeout-ms 1000
 :leader "SPC"
 :modes
 {:normal
  {"j"   :nav/scroll-down
   "k"   :nav/scroll-up
   "h"   :nav/scroll-left
   "l"   :nav/scroll-right
   "f"   :hint/start
   "C-d" :nav/half-page-down
   "C-u" :nav/half-page-up
   "C-f" :nav/page-down
   "C-b" :nav/page-up
   "g"   {"g" :nav/scroll-top "t" :tab/next "T" :tab/prev}
   "G"   :nav/scroll-bottom
   "C-w" {"h" :focus/sidebar "l" :focus/content "w" :focus/toggle "q" :tab/close}
   "C-o" :file/open-dialog
   "C-i" :history/forward
   "H"   :history/back
   "L"   :history/forward
   "/"   :search/start
   "n"   :search/next
   "N"   :search/prev
   ":"   :mode/ex
   "C-n" :tree/down
   "C-p" :tree/up
   "i"   :mode/insert
   "v"   :mode/visual
   "escape" :input/escape
   "SPC" {"f" {"f" :file/open "t" :file/open-in-new-tab "r" :file/reveal-in-tree}
          "b" {"d" :tab/close "n" :tab/next "p" :tab/prev "b" :palette/files}
          "w" {"d" :tab/close}
          "t" {"t" :theme/cycle "s" :sidebar/toggle}
          "s" {"s" :search/start}
          "SPC" :palette/open}}
  :visual
  {"escape" :mode/normal
   "j" :nav/scroll-down
   "k" :nav/scroll-up
   ":" :mode/ex}
  :insert
  {"escape" :input/escape}
  :all
  {"escape" :input/escape
   "C-o" :file/open-dialog
   "C-S-o" :file/open-dialog-new-tab
   "C-t" :tab/new-blank
   ;; font-size / zoom (whole-app, like a browser) — bind both C-= and C-+ so it works with/without Shift
   "C-0" :view/zoom-reset
   "C-=" :view/zoom-in
   "C-+" :view/zoom-in
   "C--" :view/zoom-out}}}
