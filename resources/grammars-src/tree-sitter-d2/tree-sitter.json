{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "metadata": {
    "version": "0.0.1",
    "license": "Apache-2.0",
    "description": "Permissive D2 grammar for vinary-viewer source highlighting",
    "authors": [
      {
        "name": "Vinary Tree"
      }
    ]
  },
  "grammars": [
    {
      "name": "d2",
      "camelcase": "D2",
      "scope": "source.d2",
      "path": ".",
      "file-types": [
        "d2"
      ],
      "highlights": "queries/highlights.scm"
    }
  ],
  "bindings": {
    "c": true,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
