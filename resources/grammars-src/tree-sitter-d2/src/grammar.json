            }
          },
          {
            "type": "FIELD",
            "name": "target",
            "content": {
              "type": "SYMBOL",
              "name": "_path"
            }
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "SEQ",
                "members": [
                  {
                    "type": "STRING",
                    "value": ":"
                  },
                  {
                    "type": "CHOICE",
                    "members": [
                      {
                        "type": "SYMBOL",
                        "name": "_value"
                      },
                      {
                        "type": "BLANK"
                      }
                    ]
                  }
                ]
              },
              {
                "type": "BLANK"
              }
            ]
          }
        ]
      }
    },
    "_path": {
      "type": "SEQ",
      "members": [
        {
          "type": "SYMBOL",
          "name": "_path_segment"
        },
        {
          "type": "REPEAT",
          "content": {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": "."
              },
              {
                "type": "SYMBOL",
                "name": "_path_segment"
              }
            ]
          }
        }
      ]
    },
    "_path_segment": {
      "type": "CHOICE",
      "members": [
        {
          "type": "SYMBOL",
          "name": "reserved_word"
        },
        {
          "type": "SYMBOL",
          "name": "identifier"
        },
        {
          "type": "SYMBOL",
          "name": "string"
        },
        {
          "type": "SYMBOL",
          "name": "number"
        }
      ]
    },
    "_value": {
      "type": "REPEAT1",
      "content": {
        "type": "CHOICE",
        "members": [
