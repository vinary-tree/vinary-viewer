                    {
                      "type": "PATTERN",
                      "value": "[^'\\\\\\n]"
                    },
                    {
                      "type": "PATTERN",
                      "value": "\\\\."
                    }
                  ]
                }
              },
              {
                "type": "STRING",
                "value": "'"
              }
            ]
          }
        }
      ]
    },
    "block_string": {
      "type": "TOKEN",
      "content": {
        "type": "SEQ",
        "members": [
          {
            "type": "STRING",
            "value": "|"
          },
          {
            "type": "CHOICE",
            "members": [
              {
                "type": "PATTERN",
                "value": "[A-Za-z_][A-Za-z0-9_-]*"
              },
              {
                "type": "BLANK"
              }
            ]
          },
          {
            "type": "PATTERN",
            "value": "[^|]*"
          },
          {
            "type": "STRING",
            "value": "|"
          }
        ]
      }
    },
    "number": {
      "type": "TOKEN",
      "content": {
        "type": "PATTERN",
        "value": "[+-]?(?:\\d+\\.\\d+|\\d+)(?:[eE][+-]?\\d+)?"
      }
    },
    "boolean": {
      "type": "CHOICE",
      "members": [
