{
  "$schema": "https://tree-sitter.github.io/tree-sitter/assets/schemas/config.schema.json",
  "metadata": {
    "version": "0.0.1",
    "license": "Apache-2.0",
    "description": "Permissive BNFC/LBNF grammar for vinary-viewer source highlighting",
    "authors": [
      {
        "name": "Vinary Tree"
      }
    ]
  },
  "grammars": [
    {
      "name": "bnfc",
      "camelcase": "BNFC",
      "scope": "source.bnfc",
      "path": ".",
      "file-types": [
        "cf",
        "bnfc"
      ],
      "highlights": "queries/highlights.scm"
    }
  ],
  "bindings": {
    "c": true,
    "go": false,
    "node": false,
    "python": false,
    "rust": false,
    "swift": false,
    "zig": false
  }
}
