        },
        {
          "type": "SYMBOL",
          "name": "punctuation"
        }
      ]
    },
    "keyword": {
      "type": "TOKEN",
      "content": {
        "type": "PREC",
        "value": 1,
        "content": {
          "type": "CHOICE",
          "members": [
            {
              "type": "STRING",
              "value": "comment"
            },
            {
              "type": "STRING",
              "value": "coercions"
            },
            {
              "type": "STRING",
              "value": "define"
            },
            {
              "type": "STRING",
              "value": "entrypoints"
            },
            {
              "type": "STRING",
              "value": "internal"
            },
            {
              "type": "STRING",
              "value": "layout"
            },
            {
              "type": "STRING",
              "value": "nonempty"
            },
            {
              "type": "STRING",
              "value": "position"
            },
            {
              "type": "STRING",
              "value": "rules"
            },
            {
              "type": "STRING",
              "value": "separator"
            },
            {
              "type": "STRING",
              "value": "terminator"
            },
            {
              "type": "STRING",
              "value": "token"
            },
            {
              "type": "STRING",
              "value": "toplevel"
            },
            {
              "type": "STRING",
              "value": "stop"
            }
