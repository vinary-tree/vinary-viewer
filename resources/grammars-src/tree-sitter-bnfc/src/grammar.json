            "value": "("
          },
          {
            "type": "STRING",
            "value": ")"
          },
          {
            "type": "STRING",
            "value": "["
          },
          {
            "type": "STRING",
            "value": "]"
          },
          {
            "type": "STRING",
            "value": "{"
          },
          {
            "type": "STRING",
            "value": "}"
          }
        ]
      }
    },
    "comment": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "SEQ",
            "members": [
              {
                "type": "STRING",
                "value": "--"
              },
              {
                "type": "PATTERN",
