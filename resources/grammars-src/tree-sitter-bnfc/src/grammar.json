    "punctuation": {
      "type": "TOKEN",
      "content": {
        "type": "CHOICE",
        "members": [
          {
            "type": "STRING",
            "value": "."
          },
          {
            "type": "STRING",
            "value": ";"
          },
          {
            "type": "STRING",
            "value": ","
          },
          {
