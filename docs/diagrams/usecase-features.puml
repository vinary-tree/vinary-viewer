@startuml usecase-features
'' PlantUML over Mermaid because Mermaid has no first-class use-case diagram; PlantUML models actors,
'' (use-case) ovals, system boundary rectangles, and «planned» stereotypes with per-feature colour, so
'' current and future capabilities read at a glance in the same notation as the rest of the suite.
!include _vv-theme.iuml

'' NOTE: !define colour macros (RENDERER_COLOR, …) expand only inside skinparam blocks and <<#COLOR>>
'' arrow styles; in bareword "#COLOR" and "#line:COLOR" positions PlantUML needs the LITERAL hex, so the
'' palette hexes are written out here. They are exactly the _vv-theme.iuml values (teal #2D9574 = renderer,
'' tan #9F8766 = filesystem/user, grey #DDDDDD/#999999 = «planned»).
skinparam usecase {
  BackgroundColor RENDERER_TINT
  BorderColor #1F6B53
  FontColor #1A1A1A
}
'' dashed grey «planned» variant for Forthcoming features
skinparam usecase<<planned>> {
  BackgroundColor #DDDDDD
  BorderColor #999999
  BorderStyle dashed
  FontColor #555555
}
skinparam actorStyle awesome

left to right direction

actor "User\n(reads/edits docs)" as User FS_TINT

rectangle "vinary-viewer" as VV {

  rectangle "Available now" as Now #line:1F6B53 {
    usecase "Open a file in a tab\n(`vv README.md`, click in tree)" as UC_open
    usecase "Preview Markdown\n(GFM + math + Mermaid)" as UC_md
    usecase "Live refresh on save\n(no scroll/find loss)" as UC_live
    usecase "Browse multiple tabs" as UC_tabs
    usecase "View an image\n(file://)" as UC_img
    usecase "View plain text\n(escaped HTML)" as UC_text
    usecase "View PDFs\n(native WebContentsView)" as UC_pdf
    usecase "Render Mermaid diagrams\n(fences + .mmd/.mermaid)" as UC_mermaid
    usecase "Preview source files\n(CodeMirror + tree-sitter)" as UC_src
    usecase "Load user grammars\n(~/.config/vinary-viewer)" as UC_gram
    usecase "Use custom keybindings\n(default/vim/emacs + editor)" as UC_keys
    usecase "Open HTTP links\n(in-app web view)" as UC_http
    usecase "Find in page\n(Ctrl+F, ↑/↓ cycle)" as UC_find
    usecase "Navigate history\n(Alt+←/→)" as UC_hist
    usecase "Jump via Table of Contents\n(scroll-spy)" as UC_toc
    usecase "Switch theme live\n(dark ⇆ light)" as UC_theme
    usecase "Browse git file tree\n(+ filter)" as UC_tree
    usecase "See empty-state watermark" as UC_mark
  }

  rectangle "Forthcoming (planned)" as Soon #line.dashed;line:999999 {
    usecase "Render external diagram sources\n(d2/PlantUML/Graphviz → SVG)" as UC_diag <<planned>>
  }
}

User --> UC_open
User --> UC_md
User --> UC_live
User --> UC_tabs
User --> UC_img
User --> UC_text
User --> UC_pdf
User --> UC_mermaid
User --> UC_src
User --> UC_gram
User --> UC_keys
User --> UC_http
User --> UC_find
User --> UC_hist
User --> UC_toc
User --> UC_theme
User --> UC_tree
User --> UC_mark
User ..> UC_diag

note bottom of UC_live
  Flagship capability: a file change re-renders
  document content in DataScript, while tabs,
  scroll, find, and theme stay in app-db.
end note

legend right
  |= Colour |= Concept |
  |<#2D9574>&#160;&#160;&#160;&#160;| Available now (renderer-served feature) |
  |<#DDDDDD>&#160;&#160;&#160;&#160;| Forthcoming (planned) — dashed «planned» |
  |<#9F8766>&#160;&#160;&#160;&#160;| User actor (reads/edits files) |
endlegend
@enduml
