@startuml component-common-ir
'' ============================================================================
'' vinary-viewer — Component view of the COMMON DOCUMENT IR pipeline
''
'' PlantUML over Mermaid because this is a layered dataflow where the SAME colour
'' must mean the SAME concept as in every other figure (green = markdown/HTML
'' surface, teal = renderer, gold = the trust boundary / sanitizer, blue =
'' re-frame). Only PlantUML lets us reuse the shared `_vv-theme` palette macros.
'' ============================================================================
!include _vv-theme.iuml

title Common document IR — format front-ends -> weighted-transducer IR -> HTML back-end + capabilities

package "Format front-ends (parse -> IR)" {
  component "frontend.markdown\n(rehype HAST -> IR)" as FMd  MARKDOWN_TINT
  component "frontend.office\n(office HTML -> IR)" as FOf     MARKDOWN_TINT
  component "frontend.source\n(tree-sitter -> IR)" as FSrc    RENDERER_TINT
  component "frontend.pdf\n(pdf.js text runs -> IR)" as FPdf  RENDERER_TINT
  component "frontend.{table,log,archive}" as FData           RENDERER_TINT
}

package "Common IR core  (DOM-free, node-tested)" {
  component "node / meta\ntagged node {kind,children,text,meta}\nspan / bbox / role / anchor-id" as Node IR_TINT
  component "semiring\n(K, (+), (x), 0, 1)\nBoolean/Tropical/Log/Prob/..." as Sem IR_TINT
  component "transducer\nweighted tree transducer\n(+ exact composition)" as TT IR_TINT
  component "wpda / decode\nearley / forest\n(weighted segmentation)" as Auto IR_TINT
}

package "Back-end + capabilities" {
  component "backend.html\nIR -> HAST -> rehype-stringify" as BHtml MARKDOWN_TINT
  component "backend.sanitize\nsingle GitHub allowlist" as San        IPC_TINT
  component "capability.toc\nheadings/outline -> :doc/toc" as Toc     REFRAME_TINT
}

FMd  --> Node
FOf  --> Node
FSrc --> Node
FPdf --> Node
FData --> Node

Node --> TT
Sem  --> TT
Sem  --> Auto
FPdf ..> Auto : ambiguous run->line\n->block grouping

TT   --> BHtml
BHtml --> San : one sanitizer
Node --> Toc

legend right
  |= colour |= concept |
  |<#E67E22>&#160;&#160;&#160;&#160;| common IR core |
  |<#67B11D>&#160;&#160;&#160;&#160;| HTML surface (markdown/office) |
  |<#2D9574>&#160;&#160;&#160;&#160;| renderer-side facet |
  |<#B1951D>&#160;&#160;&#160;&#160;| trust boundary / sanitizer |
  |<#4F97D7>&#160;&#160;&#160;&#160;| re-frame (:doc/toc) |
endlegend

@enduml
