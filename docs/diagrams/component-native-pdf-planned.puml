@startuml component-native-pdf-planned
'' ============================================================================
'' PlantUML over Mermaid because: this is a CROSS-PROCESS component diagram with
'' a security/IPC seam. This is a superseded legacy design retained for
'' historical comparison with component-native-pdf.puml.
'' ============================================================================
!include _vv-theme.iuml

title Native PDF (superseded legacy design) — BrowserView before WebContentsView

rectangle "Electron MAIN process" as MAIN MAIN_FILL {
  component "main.service\n(existing)" as SVC MAIN_TINT
  component "PdfService\n(legacy plan)" as PDF <<planned>>
  component "BrowserView\nlegacy design\n(Chromium PDF viewer)" as BV <<planned>>
  component "chokidar watcher\n(existing — reused)" as WATCH FS_TINT
}

rectangle "preload (contextBridge seam)" as PRE IPC_FILL {
  component "window.vv.pdfBounds(rect)\nwindow.vv.onPdfReload(cb)\n(legacy plan)" as BRIDGE <<planned>>
}

rectangle "Electron RENDERER (Chromium)" as REND RENDERER_FILL {
  component "content-view\nStrategy (existing)" as CV RENDERER_TINT
  component "pdf placeholder div\n(measured each layout)\n(legacy plan)" as PH <<planned>>
}

CV -[#B1951D,dashed,thickness=2]-> BRIDGE : (1) report placeholder bounds\n(getBoundingClientRect) over IPC
BRIDGE -[#B1951D,dashed,thickness=2]-> PDF  : (2) {x,y,w,h}
PDF -[#999999,dashed,thickness=2]-> BV      : (3) setBounds(rect)\n+ attach over the window
WATCH -[#9F8766,dashed,thickness=2]-> PDF   : (4) file change →\nBV.webContents.reload()
PDF -[#B1951D,dashed,thickness=2]-> BRIDGE  : (5) onPdfReload notify
PH .[#999999,dashed]. BV : visually occupies\nthe same rectangle

note bottom of REND
  Superseded by component-native-pdf.puml. Current runtime uses
  WebContentsView and retained-file watcher ownership; this figure is retained
  only to explain the earlier BrowserView plan.
end note

legend right
  |= color/style |= concept |
  |<#3A5BA0>&#160;&#160;&#160;&#160;| MAIN process (Node IO) — solid = existing |
  |<#B1951D>&#160;&#160;&#160;&#160;| IPC seam (contextBridge) — all IPC arrows amber |
  |<#2D9574>&#160;&#160;&#160;&#160;| renderer (Chromium UI) — solid = existing |
  |<#9F8766>&#160;&#160;&#160;&#160;| filesystem watcher (reused) |
  | dashed grey <<planned>> | superseded legacy planned component |
endlegend
@enduml
