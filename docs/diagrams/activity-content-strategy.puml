@startuml activity-content-strategy
'' Ordered Strategy selector for vinary.ui.views/content-view.
!include _vv-theme.iuml

title content-view Strategy — current document body precedence

start
:read active tab URI,\nactive doc,\nview-source flag;

if (no open tabs?) then (yes)
  :watermark; <<#2D9574>>
  stop
endif

if (doc has :doc/error?) then (yes)
  :error view; <<#E0211D>>
  stop
endif

if (active URI is HTTP/HTTPS?) then (yes)
  :HTTP web-host\n(main-owned WebContentsView); <<#3A5BA0>>
  stop
endif

if (:doc/kind = "pdf"?) then (yes)
  :PDF host\n(main-owned WebContentsView); <<#3A5BA0>>
  stop
endif

if (:doc/kind = "image"?) then (yes)
  :image preview; <<#2D9574>>
  stop
endif

if (:doc/kind = "source"?) then (yes)
  :CodeMirror source view\n(tree-sitter when grammar exists); <<#2D9574>>
  stop
endif

if (Markdown View Source?) then (yes)
  :source view over cached Markdown text; <<#2D9574>>
  stop
endif

if (:doc/html present?) then (yes)
  :markdown/text HTML body\n(form-3 innerHTML sink); <<#67B11D>>
  stop
else (no)
  :Rendering placeholder; <<#DDDDDD>>
  stop
endif

partition "Planned future branch" #line.dashed;line:999999 {
  :diagram source -> SVG strategy; <<#DDDDDD>>
  detach
}

legend right
  |= Colour |= Branch / concept |
  |<#2D9574>| renderer UI strategy |
  |<#3A5BA0>| main-owned native view |
  |<#67B11D>| Markdown/text HTML |
  |<#E0211D>| error view |
  |<#DDDDDD>| placeholder or planned future branch |
endlegend
@enduml
