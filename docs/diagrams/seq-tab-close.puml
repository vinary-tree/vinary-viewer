@startuml seq-tab-close
'' Current tab-close flow: app-db tab removal plus retained-path sync.
!include _vv-theme.iuml

title Close a tab — app-db tab removal, retained watcher/cache reconciliation

autonumber "0:"

actor User #white
participant "tab item\n(× button)" as Tabs RENDERER_TINT
participant "re-frame\n:tab/close" as RF REFRAME_TINT
collections "app-db\n[:ui :tabs]" as DB APPDB_TINT
participant "nav/close" as Nav APPDB_TINT
database "DataScript\ncontent cache" as DS DATASCRIPT_TINT
participant "preload\nwindow.vv" as Vv IPC_TINT
participant "main.service" as Svc MAIN_TINT
participant "reagent UI" as UI RENDERER_TINT

User -> Tabs : click ×\n(stopPropagation)
Tabs -> RF : dispatch [:tab/close id]
activate RF
RF -> DB : read tabs + active tab
RF -> Nav : close db id
Nav --> RF : [db' closed-uri still-open?]
RF -> RF : retained = nav/retained-file-paths(db')\ntx = ds/retract-unretained-tx(...)
RF -> DB : write updated tabs / active tab
RF -> DS : optional :ds/transact\nretract unretained cached docs
RF -> Vv : :vv/sync-retained-files retained
deactivate RF

Vv -> Svc : vv:retained-files
Svc -> Svc : sync-retained!\nclose unretained watchers

DS -> RF : :ds/changed when cache tx exists
RF -> UI : subscriptions recompute
UI -> UI : tab strip re-renders;\nwatermark if no tabs remain

legend right
  |= Colour |= Concept |
  |<#2D9574>&#160;&#160;&#160;&#160;| Renderer / UI |
  |<#4F97D7>&#160;&#160;&#160;&#160;| re-frame |
  |<#7590DB>&#160;&#160;&#160;&#160;| app-db tabs/history |
  |<#A45BAD>&#160;&#160;&#160;&#160;| DataScript content cache |
  |<#B1951D>&#160;&#160;&#160;&#160;| IPC seam |
  |<#3A5BA0>&#160;&#160;&#160;&#160;| MAIN watchers |
endlegend
@enduml
