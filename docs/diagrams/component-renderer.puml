@startuml component-renderer
'' ============================================================================
'' vinary-viewer вЂ” Component view of the RENDERER process (re-frame loop + UI)
''
'' PlantUML over Mermaid because: the renderer is a layered re-frame graph
'' (events в†’ fx в†’ side-world; subs в†ђ db / DataScript в†ђ UI) where the SAME colour
'' must mean the SAME concept as in every other figure (purple = DataScript, blue
'' = re-frame, teal = UI). Only PlantUML lets us reuse the shared `_vv-theme`
'' palette macros and draw both `dispatch` (solid) and `subscribe` (dotted) edges
'' with a self-contained legend.
'' ============================================================================
!include _vv-theme.iuml

title RENDERER process вЂ” components (`vinary.renderer.*`, `vinary.app.*`, `vinary.ui.*`)

skinparam component {
  BorderThickness 1.5
}

component "renderer.core\n`init` В· `bridge!` В· `keybindings!`(=resolver/install!) В· `mount!`" as Core RENDERER_TINT

package "re-frame machinery" {
  component "app.events\n(reg-event-db/-fx)" as Ev REFRAME_TINT
  component "app.fx\n(reg-fx вЂ” effects at the edge)" as Fx REFRAME_TINT
  component "app.subs\n(reg-sub вЂ” Observer graph)" as Sub REFRAME_TINT
}

package "state" {
  database "app.db\n(re-frame app-db:\ntabs В· history В· UI В· `:ds/rev`)" as Db APPDB_TINT
  database "app.ds\n(DataScript conn:\nbounded content cache)" as Ds DATASCRIPT_TINT
}

package "renderer services" {
  component "renderer.markdown\n(unified pipeline)" as Md MARKDOWN_TINT
  component "renderer.find\n(CSS Custom Highlight)" as Find RENDERER_TINT
  component "renderer.toc\n(offset cache В· scroll-spy)" as Toc RENDERER_TINT
}

package "reagent UI (React 19)" {
  component "ui.views\n(shell В· content-view В· toolbar В· find-bar В· toc-panel)" as Views RENDERER_TINT
  component "ui.tabs\n(tab-strip)" as Tabs RENDERER_TINT
  component "ui.tree\n(file-tree)" as Tree RENDERER_TINT
}

component "preload `window.vv`\n(IPC seam)" as Vv IPC_TINT

'' input / keybinding layer вЂ” LIVE (resolver installed by keybindings!).
package "input / keybindings" {
  component "input.resolver\n(keydown в†’ trie-walk в†’ decision)" as Res RENDERER_TINT
  component "app.commands\n(command registry В· run)" as Cmd RENDERER_TINT
  component "input.keymap\n(presets <latex>\oplus</latex> user В· modes)" as Kmap RENDERER_TINT
  component "input.events / input.fx\n(:input/* В· :palette/* В· :dom/*)" as Iev REFRAME_TINT
}
component "ui.palette\n(command-palette view)" as Pal RENDERER_TINT

Core --> Ev   : `dispatch-sync [:db/init]`
Core --> Vv   : `bridge!` wires content/tree/config/web channels
Vv ..> Ev     : amber: payload вџ¶ `[:content/received]` вЂ¦
Ev --> Db     : updates ephemeral UI
Ev --> Fx     : `:fx` vector
Fx --> Ds     : `:ds/transact`
Fx --> Md     : `:markdown/render`
Fx --> Find   : `:find/run` В· `:find/cycle` В· `:find/clear`
Fx --> Toc    : `:toc/scroll`
Fx ..> Vv     : `:vv/open` В· retained sync В· shell/config fx (amber)
Md ..> Ev     : `.then` вџ¶ `[:content/rendered]`
Ds ..> Db     : `d/listen!` вџ¶ `[:ds/changed]` (bumps `:ds/rev`)

Sub ..> Db    : reads ephemeral UI
Sub ..> Ds    : reads conn (gated on `:<- [:ds/rev]`)
Sub ..> Ds    : `:doc/toc` reads stored render metadata

Views ..> Sub : `subscribe`
Tabs ..> Sub  : `subscribe`
Tree ..> Sub  : `subscribe`
Views --> Ev  : `dispatch` (theme/find/toc)
Tabs --> Ev   : `dispatch` (`:tab/activate` В· `:tab/close`)
Tree --> Ev   : `dispatch` (`:doc/open` В· `:tree/filter`)
Views ..> Toc : `spy!` on scroll

Core --> Res  : `keybindings!` = `resolver/install!`
Res ..> Db    : reads ctx (mode В· sequence) from app-db
Res --> Cmd   : `commands/run` (decision в†’ command id)
Res --> Kmap  : active keymap `modes`
Cmd --> Ev    : `rf/dispatch` resolved command's event
Iev --> Db    : modal / palette state
Vv ..> Iev    : amber: `onKeymap` вџ¶ `[:keymap/config-received]`
Iev ..> Pal   : palette state drives visible command picker

legend right
  |= Colour |= Concept |
  |<#2D9574>&#160;&#160;&#160;&#160;| Renderer / UI / services / input |
  |<#4F97D7>&#160;&#160;&#160;&#160;| re-frame machinery |
  |<#A45BAD>&#160;&#160;&#160;&#160;| DataScript content cache |
  |<#7590DB>&#160;&#160;&#160;&#160;| app-db (tabs, history, UI) |
  |<#67B11D>&#160;&#160;&#160;&#160;| markdown / unified |
  |<#B1951D>&#160;&#160;&#160;&#160;| IPC seam |
  Solid = dispatch / effect В· Dotted = subscribe / listen
endlegend
@enduml
