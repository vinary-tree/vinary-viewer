@startuml component-grammar-registry
'' PlantUML over Mermaid because this component view uses the shared vinary-viewer color theme and shows both main-process filesystem discovery and renderer consumption.
!include _vv-theme.iuml

title Bundled and user tree-sitter grammar registry

skinparam componentStyle rectangle

package "Main process" MAIN_FILL {
  [bundled grammar catalog\ncompiled resources/public/grammars] as Bundled MAIN_TINT
  [user grammar scanner\n~/.config/vinary-viewer/grammars/<lang>] as Scanner FS_TINT
  [vv:grammars request handler\npush EDN config vector] as Push IPC_TINT
}

package "Renderer process" RENDERER_FILL {
  [renderer grammar catalog\nbundled + user entries] as Registry DATASCRIPT_TINT
  [source preview\nlookup by extension] as SourceView RENDERER_TINT
  [Markdown fenced code\nlookup by language id] as Markdown MARKDOWN_TINT
}

Bundled -[#27406F,thickness=2]-> Registry : bundled-grammars
Scanner -[#6F5E47,thickness=2]-> Push : valid files found\n(grammar.wasm + highlights.scm)
Push -[#7F6B14,thickness=2]-> Registry : vv:grammars EDN
Registry -[#336699,thickness=2]-> SourceView : grammar-for(path)
Registry -[#487E12,thickness=2]-> Markdown : grammar-for-language(id)

legend
  |<#3A5BA0>&#160;&#160;&#160;&#160;| bundled grammar metadata ships with the app |
  |<#9F8766>&#160;&#160;&#160;&#160;| user grammar files live under the config directory |
  |<#B1951D>&#160;&#160;&#160;&#160;| IPC mediator transfers user grammar entries |
  |<#A45BAD>&#160;&#160;&#160;&#160;| renderer catalog combines bundled and user entries |
  |<#2D9574>&#160;&#160;&#160;&#160;| source preview consumes grammars by file extension |
  |<#67B11D>&#160;&#160;&#160;&#160;| Markdown fenced code consumes grammars by language id |
endlegend

@enduml
