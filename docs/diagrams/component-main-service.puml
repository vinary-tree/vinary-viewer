@startuml component-main-service
'' Main process component view. PlantUML is used for colored component groups,
'' notes, and explicit IPC/native-resource boundaries.
!include _vv-theme.iuml

title MAIN process components (`vinary.main.*`) — current native/IO services

skinparam component {
  BorderThickness 1.5
}

component "vinary.main.core" as Core MAIN_TINT
note bottom of Core
  app lifecycle
  BrowserWindow creation
  initial argv file
end note

component "vinary.main.service" as Svc MAIN_TINT
note bottom of Svc
  read + classify files
  reconcile retained watchers
  watch Markdown assets
  send content/errors/tree
end note

component "vinary.main.file-kind" as Kind MAIN_TINT
component "vinary.main.pdf" as Pdf MAIN_TINT
component "vinary.main.web" as Web MAIN_TINT
component "vinary.main.config" as Config MAIN_TINT
component "vinary.main.settings" as Settings MAIN_TINT
component "vinary.main.grammars" as Grammars MAIN_TINT

component "ipcMain handlers" as Ipc IPC_FILL {
  portin "vv:open" as POpen
  portin "vv:retained-files" as PRetained
  portin "vv:watch-assets" as PAssets
  portin "vv:pdf-*" as PPdf
  portin "vv:http-*" as PHttp
  portin "vv:keymap-*" as PKeymap
  portin "vv:settings-*" as PSettings
  portin "vv:grammars-request" as PGrammars
}

component "preload\ncontextBridge `window.vv`" as Preload IPC_TINT

cloud "Node built-ins\n(fs · path · child_process)" as Node FS_TINT
cloud "chokidar\n(retained file + asset watchers)" as Chk FS_TINT
cloud "git CLI\n(rev-parse · ls-files)" as Git FS_TINT
cloud "Electron native views\nWebContentsView" as Native FS_TINT
database "~/.config/vinary-viewer" as Conf FS_TINT

Core --> Svc : init and initial open
Core --> Preload : webPreferences.preload
Core --> Pdf : init
Core --> Web : init
Core --> Config : init
Core --> Settings : init
Core --> Grammars : init

Svc --> Kind : classify
Svc --> Node : read files
Svc --> Chk : retained watchers
Svc --> Git : repo tree
Pdf --> Native : PDF WebContentsView
Web --> Native : HTTP WebContentsView
Config --> Conf : keybindings.edn
Settings --> Conf : settings.edn
Grammars --> Conf : grammars/<lang>\nfiletypes.edn

Svc --> Ipc : register handlers
Pdf --> Ipc
Web --> Ipc
Config --> Ipc
Settings --> Ipc
Grammars --> Ipc

POpen --> Svc
PRetained --> Svc
PAssets --> Svc
PPdf --> Pdf
PHttp --> Web
PKeymap --> Config
PSettings --> Settings
PGrammars --> Grammars

Svc ..> Preload : vv:content / vv:error / vv:tree
Web ..> Preload : vv:http-navigated / vv:web-toc
Config ..> Preload : vv:keymap
Settings ..> Preload : vv:settings
Grammars ..> Preload : vv:grammars

legend right
  |= Colour |= Concept |
  |<#3A5BA0>&#160;&#160;&#160;&#160;| MAIN / Node service |
  |<#B1951D>&#160;&#160;&#160;&#160;| IPC seam |
  |<#9F8766>&#160;&#160;&#160;&#160;| external/native resource |
endlegend
@enduml
