@startuml seq-extension-install
'' Sequence: installing a Chrome extension from Settings ▸ Extensions through the GPL-free runtime
'' (Electron's built-in loader + electron-chrome-web-store, MIT). The spike proved Electron 42 provides
'' chrome.* natively, so there is NO shim/preload — main just reads the manifest to drive the toolbar.
'' (PlantUML over Mermaid: participant colouring + activation lanes across the seam.)
!include _vv-theme.iuml

title Extension install (GPL-free runtime — ADR-0015)

actor User
participant "Extensions\ndialog" as UI REFRAME_TINT
participant "preload\nwindow.vv" as IPC IPC_TINT
participant "main\nextensions" as EXT MAIN_TINT
participant "electron-chrome\n-web-store (MIT)" as WS FS_TINT
participant "session.extensions\n(built-in, MIT)" as SES KEYMAP_TINT
participant "ext-toolbar\n(renderer)" as TB RENDERER_TINT

User -> UI : paste Web Store URL/ID → Install
activate UI
UI -> IPC : vv:ext-install (idOrUrl)
deactivate UI
IPC -> EXT : install!
activate EXT
EXT -> EXT : ext-util/parse-store-id → [a-p]{32}
EXT -> WS : installExtension(id, { session, extensionsPath })
activate WS
WS -> SES : download + unpack + loadExtension
SES --> EXT : "extension-loaded" (manifest, path)
deactivate WS
EXT -> EXT : manifest → action model;\nicon bytes → data-URL (magic-sniffed, capped)
EXT -> TB : vv:ext-state { :installed [...] }
deactivate EXT
activate TB
TB -> TB : render action icon in the address-bar row
note over TB : click → vv:ext-action-clicked → main opens\nthe popup (its chrome.* work natively — no shim)
deactivate TB
@enduml
