@startuml seq-toc
'' Current TOC flow: render metadata plus cached DOM offsets.
!include _vv-theme.iuml

title Scroll-spy TOC — render metadata, cached offsets, binary-search spy

autonumber

participant "markdown render\nHAST traversal" as MD MARKDOWN_TINT
participant "DataScript\n:doc/toc + :doc/html" as DS DATASCRIPT_TINT
participant ".markdown-body\nDOM" as BODY RENDERER_TINT
participant "figures/scale-figures!" as FIG RENDERER_TINT
participant "toc/refresh-offsets!" as OFF RENDERER_TINT
participant ".vv-content\nscroll container" as CONTENT RENDERER_TINT
participant "toc/spy!" as SPY RENDERER_TINT
participant "re-frame" as RF REFRAME_TINT
participant "Contents panel" as PANEL RENDERER_TINT

== render commit ==
MD -> DS : {:html :toc :assets}
DS -> RF : :ds/rev changes
RF -> PANEL : :doc/toc subscription\nreads cached metadata
RF -> BODY : set innerHTML
BODY -> FIG : measure local SVGs\napply style only when changed
FIG -> OFF : after sizing settles
OFF -> OFF : cache [{id, offsetTop}]

== scroll-spy ==
CONTENT -> SPY : scroll event
SPY -> SPY : requestAnimationFrame coalescing
SPY -> OFF : read cached offsets
SPY -> SPY : binary search by scrollTop
SPY -> RF : [:toc/active-heading id]
RF -> PANEL : active item gets .vv-toc-active

== click ==
PANEL -> RF : [:toc/goto id]
RF -> CONTENT : scroll heading into view

legend right
  |= color |= concept |
  |<#67B11D>&#160;&#160;&#160;&#160;| Markdown render pipeline |
  |<#A45BAD>&#160;&#160;&#160;&#160;| DataScript content cache |
  |<#4F97D7>&#160;&#160;&#160;&#160;| re-frame event/subscription layer |
  |<#2D9574>&#160;&#160;&#160;&#160;| renderer DOM/runtime |
endlegend
@enduml
