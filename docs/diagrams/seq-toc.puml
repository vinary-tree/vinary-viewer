@startuml seq-toc
'' Current TOC flow: render metadata plus cached DOM offsets.
!include _vv-theme.iuml

title Scroll-spy TOC — render metadata, cached offsets, binary-search spy

autonumber

participant "markdown render\nHAST traversal" as MD #67B11D
participant "DataScript\n:doc/toc + :doc/html" as DS #A45BAD
participant ".markdown-body\nDOM" as BODY #2D9574
participant "figures/scale-figures!" as FIG #2D9574
participant "toc/refresh-offsets!" as OFF #2D9574
participant ".vv-content\nscroll container" as CONTENT #2D9574
participant "toc/spy!" as SPY #2D9574
participant "re-frame" as RF #4F97D7
participant "Contents panel" as PANEL #2D9574

== render commit ==
MD -> DS : {:html :toc :assets}
DS -> RF : :ds/rev changes
RF -> PANEL : :doc/toc subscription\nreads cached metadata
RF -> BODY : set innerHTML
BODY -> FIG : measure local SVGs\napply style only when changed
FIG -> OFF : after sizing settles
OFF -> OFF : cache [{id, offsetTop}]

== scroll-spy ==
CONTENT -> SPY : scroll event
SPY -> SPY : requestAnimationFrame coalescing
SPY -> OFF : read cached offsets
SPY -> SPY : binary search by scrollTop
SPY -> RF : [:toc/active-heading id]
RF -> PANEL : active item gets .vv-toc-active

== click ==
PANEL -> RF : [:toc/goto id]
RF -> CONTENT : scroll heading into view

legend right
  |= color |= concept |
  | <#67B11D> | Markdown render pipeline |
  | <#A45BAD> | DataScript content cache |
  | <#4F97D7> | re-frame event/subscription layer |
  | <#2D9574> | renderer DOM/runtime |
endlegend
@enduml
