@startuml component-tree-sitter-planned
'' ============================================================================
'' PlantUML over Mermaid because: this is a layered component pipeline (file →
'' incremental parser → capture → CSS style-map → CodeMirror decorations). This
'' is a superseded legacy design retained for comparison with
'' component-source-preview.puml.
'' ============================================================================
!include _vv-theme.iuml

title Source preview via tree-sitter (superseded legacy design)

rectangle "Electron RENDERER (Chromium)" as REND #2D9574 {
  component "source-view\nStrategy entry" as SV <<planned>>

  package "read-only CodeMirror 6 editor" <<planned>> {
    component "EditorState\n(doc text from :doc/text)\n(legacy plan)" as STATE <<planned>>
    component "ViewPlugin\n(viewport-cached decorations)\n(legacy plan)" as VP <<planned>>
    component "StateField\n(incremental parse tree)\n(legacy plan)" as SF <<planned>>
  }

  package "web-tree-sitter (WASM)" <<planned>> {
    component "Parser\nParser.parse(text, oldTree)\n[incremental: Wagner & Graham 1998]\n(legacy plan)" as PARSER <<planned>>
    component "Query (highlights.scm)\ncapture → name\n(legacy plan)" as QUERY <<planned>>
    component "capture → CSS class\nstyle-map\n(legacy plan)" as STYLEMAP <<planned>>
  }
}

rectangle "grammar source" as GR #9F8766 {
  component "Language.load(<name>.wasm)\n(legacy plan)" as LANG <<planned>>
}

LANG  -[#999999,dashed,thickness=2]-> PARSER : (1) load grammar WASM\n(bundled base64 or user registry)
STATE -[#999999,dashed,thickness=2]-> PARSER : (2) parse(text, oldTree)
PARSER -[#999999,dashed,thickness=2]-> SF    : (3) syntax tree → StateField
SF    -[#999999,dashed,thickness=2]-> QUERY  : (4) run highlight query over tree
QUERY -[#999999,dashed,thickness=2]-> STYLEMAP : (5) capture names
STYLEMAP -[#2D9574,dashed,thickness=2]-> VP  : (6) class per range → Decorations
VP    -[#2D9574,dashed,thickness=2]-> SV     : (7) styled, read-only source

note bottom of REND
  Superseded by component-source-preview.puml. Current runtime provides
  read-only CodeMirror 6 source previews with grammar registry integration.
end note

legend right
  |= color/style |= concept |
  | <#2D9574> | renderer (Chromium UI) |
  | <#9F8766> | grammar source (filesystem / registry) |
  | dashed grey <<planned>> | superseded legacy planned component |
endlegend
@enduml
